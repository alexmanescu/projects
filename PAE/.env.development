# PAE — Development environment
# Copy to .env and fill in real values.
# This file is safe to commit (no real secrets).

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://pae_user:dev_password@localhost:3306/pae_dev

# ── LLM — Ollama (local) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b

# ── LLM — Claude (fallback) ───────────────────────────────────────────────────
# Leave blank to disable Claude fallback in development.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Alpaca (paper trading) ────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Safety defaults (development: nothing executes) ───────────────────────────
DRY_RUN=true
PAPER_TRADING=true

# ── Scheduler ─────────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
