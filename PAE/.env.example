# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://user:password@host/database

# ── LLMs ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:30b
ANTHROPIC_API_KEY=

# ── Brokers ───────────────────────────────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Prediction Markets ────────────────────────────────────────────────────────
KALSHI_API_KEY=
KALSHI_SECRET=

# ── Runtime ───────────────────────────────────────────────────────────────────
# DRY_RUN=true skips all external side-effects (DB writes, trades, Telegram)
DRY_RUN=true
PAPER_TRADING=true
CHECK_INTERVAL_MINUTES=60
LOG_LEVEL=INFO
